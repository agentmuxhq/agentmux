{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "AgentMux",
  "version": "0.21.2",
  "identifier": "com.a5af.agentmux",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/frontend",
    "beforeDevCommand": "npx vite --config vite.config.tauri.ts",
    "beforeBuildCommand": "npx vite build --config vite.config.tauri.ts"
  },
  "app": {
    "windows": [
      {
        "title": "AgentMux",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: http://ipc.localhost; connect-src 'self' tauri: ipc: http://ipc.localhost http://tauri.localhost; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: wavefile:; media-src 'self' wavefile:; frame-src 'self' wavefile:; font-src 'self' data:;"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "externalBin": [
      "binaries/wsh"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/a5af/agentmux/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyRTQwODUxNDg3MjhEMzUKUldRMWpYSklVUWprWXIyT1lmSTlQM2J4WVc2bk44U2RJdEx2THVpdmpUUDhjKytZQnhEUzgzRnYK"
    }
  }
}
